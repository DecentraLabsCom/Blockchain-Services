# -----------------------------------------------------------------------------
# SMART CONTRACT CONFIGURATION
# -----------------------------------------------------------------------------
CONTRACT_ADDRESS=0xe49a2f59631717691642f929E0FeF1f705866600
BLOCKCHAIN_NETWORK_ACTIVE=sepolia
# Contract execution gas limit used by on-chain writes (intent execution, billing ops, etc.)
ETHEREUM_GAS_PRICE_DEFAULT=5
ETHEREUM_GAS_PRICE_STRATEGY=network
ETHEREUM_GAS_LIMIT_CONTRACT=1000000
# Direct booking atomically executes request+confirm in a single tx and needs more gas.
# Must exceed ~1.5M to cover the treasury spend and finalization steps.
ETHEREUM_GAS_LIMIT_DIRECT_BOOKING=2000000

# Generic institutional transaction replacement safeguards (all amounts in wei).
INSTITUTIONAL_TRANSACTION_OUTBOX_MONITOR_MAX_GAS_PRICE_WEI=100000000000
INSTITUTIONAL_TRANSACTION_OUTBOX_MONITOR_MAX_MULTIPLIER=3
INSTITUTIONAL_TRANSACTION_OUTBOX_MONITOR_MAX_ESTIMATED_TRANSACTION_COST_WEI=100000000000000000

# -----------------------------------------------------------------------------
# NETWORK-SPECIFIC RPC URLs (with automatic failover)
# -----------------------------------------------------------------------------
# Format: comma-separated list - tries each endpoint in order
# Service tries each URL in order until one succeeds
# Recommended: Mix free public endpoints or use paid services for reliability
#
# Free providers with API keys:
# - Infura: https://infura.io (100k requests/day free)
# - Alchemy: https://alchemy.com (300M compute units/month free)
ETHEREUM_MAINNET_RPC_URL=https://eth.public-rpc.com
ETHEREUM_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com,https://0xrpc.io/sep,https://ethereum-sepolia-public.nodies.app

# -----------------------------------------------------------------------------
# CONTRACT EVENT LISTENING
# -----------------------------------------------------------------------------
CONTRACT_EVENT_POLLING_ENABLED=true
CONTRACT_EVENT_POLLING_INTERVAL=60
CONTRACT_EVENT_POLLING_BLOCK_RANGE=1000
CONTRACT_EVENT_POLLING_LOOKBACK=100
# Production listeners require the MySQL journal. Disable only for isolated tests.
CONTRACT_EVENT_PERSISTENCE_REQUIRED=true
CONTRACT_EVENT_PROCESSING_MAX_ATTEMPTS=10
CONTRACT_EVENT_PROCESSING_RETRY_DELAY_SECONDS=60
CONTRACT_EVENT_PROCESSING_LEASE_TIMEOUT_SECONDS=300
BILLING_ADMIN_TRANSACTIONS_LOOKBACK_BLOCKS=30000

# -----------------------------------------------------------------------------
# INSTITUTIONAL WALLET (optional overrides)
# -----------------------------------------------------------------------------
# Normally you create/import the institutional wallet via /wallet-dashboard.
# The app then stores the encrypted key in /app/data/wallets.json and writes
# address/password to /app/data/wallet-config.properties. Leave these empty to
# rely on that auto-configuration. Only set them if you need to override with
# external secret management (env vars take precedence over the config file).
INSTITUTIONAL_WALLET_ADDRESS=
INSTITUTIONAL_WALLET_PASSWORD=
WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# -----------------------------------------------------------------------------
# WALLET PERSISTENCE
# -----------------------------------------------------------------------------
WALLET_PERSISTENCE_ENABLED=true
WALLET_FILE_PATH=/app/data/wallets.json

# REQUIRED for wallet persistence: Encryption key for wallet password storage
# Leave empty to let the service auto-generate it into WALLET_CONFIG_KEY_FILE
WALLET_CONFIG_ENCRYPTION_KEY=
# Persistent file that stores the auto-generated encryption key (must be mounted)
WALLET_CONFIG_KEY_FILE=/app/data/.wallet-encryption-key

# Separate 32-byte AES-256 key (base64 or base64url) for encrypted pending
# intent execution payloads. Required when intent persistence is enabled.
INTENT_PAYLOAD_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# DATABASE (optional; required for persistence features)
# -----------------------------------------------------------------------------
# Example: jdbc:mysql://mysql:3306/guacamole_db?serverTimezone=UTC&characterEncoding=UTF-8&useSSL=false
BLOCKCHAIN_MYSQL_ROOT_PASSWORD=change-me
BLOCKCHAIN_MYSQL_DATABASE=blockchain_services
BLOCKCHAIN_MYSQL_USER=blockchain
BLOCKCHAIN_MYSQL_PASSWORD=blockchain

# -----------------------------------------------------------------------------
# GUACAMOLE PROVISIONER (optional for remote/Lite)
# -----------------------------------------------------------------------------
# Embedded Full Gateway works with defaults and LAB_MANAGER_TOKEN.
# With one shared Lite LAB_MANAGER_TOKEN, non-local accessURI origins derive
# their provisioner URL as <origin>/gateway-provisioner/guacamole.
# See ../docs/deployment-architectures.md for Full/Lite topologies.
GUACAMOLE_PROVISIONER_TOKEN=
# Use this when one backend serves multiple Lite gateways with different
# LAB_MANAGER_TOKEN values or route overrides. Keys are accessURI origins or hosts.
# {"https://lite-a.example":{"token":"CHANGE_ME"},"https://lite-b.example":{"token":"CHANGE_ME"}}
GUACAMOLE_PROVISIONER_ROUTES_JSON=

# -----------------------------------------------------------------------------
# JWT KEY PATHS
# -----------------------------------------------------------------------------
# Keep defaults unless mounting keys from a different location. The Gateway
# provides /app/data through the private blockchain-data volume; TLS material
# in /etc/ssl/private is intentionally not mounted into this service.
PRIVATE_KEY_PATH=/app/data/keys/private_key.pem
PUBLIC_KEY_PATH=/app/data/keys/public_key.pem

# -----------------------------------------------------------------------------
# SAML/SSO CONFIGURATION
# -----------------------------------------------------------------------------
# SIR2/RedIRIS FPP runs SimpleSAMLphp. The entityID issuer ends in /idp but the
# metadata lives at /saml2/idp/metadata.php (not /idp/metadata which returns 404).
# Replace the tenant slug with your institution's tenant as registered in SIR2 FPP.
SAML_IDP_METADATA_OVERRIDE={"https://fpp.sir2.rediris.es/es.decentralabs.marketplace/idp":"https://fpp.sir2.rediris.es/es.decentralabs.marketplace/saml2/idp/metadata.php"}
# Optional per-issuer TLS profile. Keep the secure modern profile by default;
# use compatibility only for a named issuer whose metadata endpoint requires it.
SAML_IDP_METADATA_TLS_PROFILE={}

# trust-mode:
#   - 'any': Trust any IdP with valid SAML signature (flexible, less secure)
#   - 'whitelist': Only trust specific IdPs listed below (recommended for production)
SAML_IDP_TRUST_MODE=any
SAML_METADATA_ALLOW_HTTP=false
SAML_METADATA_HTTP_CONNECT_TIMEOUT_MS=5000
SAML_METADATA_HTTP_READ_TIMEOUT_MS=10000
SAML_METADATA_HTTP_CALL_TIMEOUT_MS=15000
SAML_METADATA_CERTIFICATE_CACHE_MS=300000
SAML_METADATA_REFRESH_INTERVAL_MS=30000
SAML_METADATA_REFRESH_INITIAL_DELAY_MS=0
# Trusted IdP Issuers (only used if trust-mode=whitelist)
# Format: {'institutionId':'idpIssuerUrl', 'institutionId2':'idpIssuerUrl2'}
SAML_TRUSTED_IDP={'uned':'https://idp.uned.es','ucm':'https://idp.ucm.es'}
JAVA_OPTS=-Djdk.tls.client.protocols=TLSv1.2 -Dhttps.protocols=TLSv1.2 -Djava.net.preferIPv4Stack=true -Djava.net.preferIPv6Addresses=false

# -----------------------------------------------------------------------------
# WEBAUTHN CONFIGURATION
# -----------------------------------------------------------------------------
WEBAUTHN_CREDENTIALS_TABLE=webauthn_credentials
# Keep true in any deployment that accepts reservations; false is only for isolated memory-only development.
WEBAUTHN_CREDENTIALS_REQUIRE_DATABASE=true
WEBAUTHN_CREDENTIALS_MAX_AGE_DAYS=365
WEBAUTHN_CREDENTIALS_REVOKE_INTERVAL_MS=86400000
WEBAUTHN_RP_NAME=DecentraLabs Gateway
WEBAUTHN_RP_ORIGINS=https://localhost,https://localhost:443,https://localhost:8443
WEBAUTHN_TIMEOUT_MS=120000
WEBAUTHN_SESSION_TTL_SECONDS=300
WEBAUTHN_SESSION_CLEANUP_INTERVAL_SECONDS=60
WEBAUTHN_ATTESTATION_CONVEYANCE=none
WEBAUTHN_AUTHENTICATOR_ATTACHMENT=
WEBAUTHN_RESIDENT_KEY=preferred
# Required by the verifier because WebAuthn credentials authorize spending intents.
WEBAUTHN_USER_VERIFICATION=required

# -----------------------------------------------------------------------------
# FEATURE TOGGLES
# -----------------------------------------------------------------------------
# Enable Treasury and Provider management features
FEATURES_PROVIDERS_ENABLED=false
FEATURES_ORGANIZATIONS_ENABLED=true
FEATURES_PROVIDERS_REGISTRATION_ENABLED=false

# -----------------------------------------------------------------------------
# ORGANIZATION INVITES
# -----------------------------------------------------------------------------
ORGANIZATION_INVITE_HMAC_SECRET=
ORGANIZATION_INVITE_DEFAULT_ISSUER=DecentraLabs Marketplace

# -----------------------------------------------------------------------------
# ANTI-REPLAY PROTECTION
# -----------------------------------------------------------------------------
# For single instance: false (uses in-memory cache with 5 min expiration)
# For multiple instances: true (requires Redis)
ANTIREPLAY_PERSISTENCE_ENABLED=false

# -----------------------------------------------------------------------------
# INTENTS CONFIGURATION
# -----------------------------------------------------------------------------
INTENT_TRUSTED_SIGNER=
INTENT_DEFAULT_ETA=15s
INTENT_DOMAIN_NAME=DecentraLabsIntent
INTENT_DOMAIN_VERSION=1
INTENT_DOMAIN_CHAIN_ID=11155111
BILLING_ADMIN_DOMAIN_NAME=DecentraLabsTreasuryAdmin
BILLING_ADMIN_DOMAIN_VERSION=1
BILLING_ADMIN_DOMAIN_CHAIN_ID=11155111
INTENT_RECONCILIATION_INTERVAL_MS=10000
INTENT_EXECUTION_INTERVAL_MS=1000
INTENT_WEBHOOK_URL=
INTENT_WEBHOOK_SECRET=
CONTRACT_RESERVATION_RECONCILE_ENABLED=true
CONTRACT_RESERVATION_RECONCILE_INTERVAL_MS=120000
CONTRACT_RESERVATION_RECONCILE_MIN_AGE_SECONDS=120
CONTRACT_RESERVATION_RECONCILE_BATCH_SIZE=50
INTENTS_AUTH_ENABLED=true
INTENTS_AUTH_ISSUER=marketplace
# Exact public origin of this backend, e.g. https://gateway.example.edu
INTENTS_AUTH_AUDIENCE=
# Institution identifier served by this backend, e.g. example.edu
INTENTS_AUTH_INSTITUTION_ID=
INTENTS_AUTH_SERVICE_SUBJECT=marketplace
INTENTS_AUTH_MAX_TTL_SECONDS=60
INTENTS_AUTH_SUBMIT_SCOPE=intents:submit
INTENTS_AUTH_AUTHORIZE_SCOPE=intents:authorize
INTENTS_AUTH_REGISTRATION_MINED_SCOPE=intents:registration-mined
INTENTS_AUTH_STATUS_SCOPE=intents:status
INTENTS_AUTH_CLOCK_SKEW_SECONDS=60

# -----------------------------------------------------------------------------
# SECURITY & API
# -----------------------------------------------------------------------------
BASE_DOMAIN=
ALLOWED_ORIGINS=http://localhost:3000,https://marketplace-decentralabs.vercel.app
MARKETPLACE_PUBLIC_KEY_URL=https://marketplace-decentralabs.vercel.app/.well-known/public-key.pem
MARKETPLACE_URL=https://marketplace-decentralabs.vercel.app
# Marketplace-originated JWTs must target this backend's exact public origin.
# Use the same origin configured in INTENTS_AUTH_AUDIENCE where applicable.
AUTH_MARKETPLACE_ENDPOINTS_AUDIENCE=
# Institution identifier served by this backend, e.g. example.edu
AUTH_MARKETPLACE_ENDPOINTS_INSTITUTION_ID=
AUTH_MARKETPLACE_ENDPOINTS_SERVICE_SUBJECT=marketplace
AUTH_MARKETPLACE_ENDPOINTS_MAX_TTL_SECONDS=60
LOG_LEVEL_AUTH=INFO
LOG_LEVEL_SECURITY=WARN
LOG_LEVEL_WEB=WARN
LOG_LEVEL_ROOT=INFO

# Cross-institutional check-in: provider gateways delegate the on-chain
# check-in signature to the payer institution's registered backend when the
# local wallet is not authorized for that institution.
INSTITUTIONAL_CHECKIN_DELEGATION_ENABLED=true
INSTITUTIONAL_CHECKIN_DELEGATION_ENDPOINT_PATH=/auth/checkin-institutional

# -----------------------------------------------------------------------------
# MARKETPLACE AUTO-REGISTRATION
# -----------------------------------------------------------------------------
MARKETPLACE_BASE_URL=
PROVIDER_NAME=
PROVIDER_EMAIL=
PROVIDER_COUNTRY=
PROVIDER_ORGANIZATION=
# Non-zero 0x-prefixed bytes32 PUC hash for Gateway-created labs.
PROVIDER_PUC_HASH=
PUBLIC_BASE_URL=

# -----------------------------------------------------------------------------
# ADMIN DASHBOARD ACCESS
# -----------------------------------------------------------------------------
# Restrict wallet-dashboard and wallet/billing routes to localhost by default.
# Set ADMIN_DASHBOARD_ALLOW_PRIVATE=true only if you explicitly want access from
# private network ranges and protect it with ADMIN_ACCESS_TOKEN.
ADMIN_DASHBOARD_LOCAL_ONLY=true
ADMIN_DASHBOARD_ALLOW_PRIVATE=false
ADMIN_ALLOWED_CIDRS=
# Trust forwarded client IP headers only from loopback and Docker-style internal proxies by default.
# The policy walks the chain from right to left and selects the first untrusted hop.
# Extend this with every trusted reverse-proxy CIDR when deploying behind an external proxy.
SECURITY_TRUSTED_PROXY_CIDRS=127.0.0.1/8,::1/128,172.16.0.0/12
PROVISIONING_TOKEN_HTTP_CONNECT_TIMEOUT_MS=5000
PROVISIONING_TOKEN_HTTP_READ_TIMEOUT_MS=10000

# -----------------------------------------------------------------------------
# SPRING BOOT / TOMCAT
# -----------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=default

# -----------------------------------------------------------------------------
# BOOKINGS NOTIFICATIONS (email + ICS)
# -----------------------------------------------------------------------------
NOTIFICATIONS_MAIL_ENABLED=true
NOTIFICATIONS_MAIL_DRIVER=noop
NOTIFICATIONS_MAIL_FROM=
NOTIFICATIONS_MAIL_FROM_NAME=Lab Gateway
NOTIFICATIONS_MAIL_DEFAULT_TO=
NOTIFICATIONS_MAIL_TIMEZONE=UTC

# SMTP (driver=smtp)
NOTIFICATIONS_MAIL_SMTP_HOST=
NOTIFICATIONS_MAIL_SMTP_PORT=587
NOTIFICATIONS_MAIL_SMTP_USERNAME=
NOTIFICATIONS_MAIL_SMTP_PASSWORD=
NOTIFICATIONS_MAIL_SMTP_AUTH=true
NOTIFICATIONS_MAIL_SMTP_STARTTLS=true
NOTIFICATIONS_MAIL_SMTP_TIMEOUT_MS=10000

# Microsoft Graph (driver=graph)
NOTIFICATIONS_MAIL_GRAPH_TENANT_ID=
NOTIFICATIONS_MAIL_GRAPH_CLIENT_ID=
NOTIFICATIONS_MAIL_GRAPH_CLIENT_SECRET=
NOTIFICATIONS_MAIL_GRAPH_FROM=
NOTIFICATIONS_CONFIG_FILE=./data/notifications-config.json

# SECURITY (application-level names consumed by Spring Boot)
# Use ADMIN_ACCESS_TOKEN for treasury/admin access protection.
ADMIN_ACCESS_TOKEN=
ADMIN_ACCESS_TOKEN_HEADER=X-Access-Token
ADMIN_ACCESS_TOKEN_COOKIE=access_token
ADMIN_ACCESS_TOKEN_REQUIRED=true
SECURITY_ALLOW_PRIVATE_NETWORKS=false

# Gateway-specific credentials. Use distinct strong values per gateway and keep
# the JSON maps in a secret manager in production.
# Example: {"full-gateway":"CHANGE_ME"}
ACCESS_CODE_REDEEMER_CREDENTIALS_JSON={}
# Example: {"full-gateway":"<short-lived-observer-credential>"}
SESSION_OBSERVER_CREDENTIALS_JSON={}

# Dedicated Lab Manager boundary for /lab-admin/** only.
LAB_MANAGER_TOKEN=
LAB_MANAGER_TOKEN_HEADER=X-Lab-Manager-Token
LAB_MANAGER_ALLOWED_CIDRS=

# Persistent provider-lab metadata, images and PDF documents. This directory
# must be mounted in the service container and contains only public content.
LAB_CONTENT_BASE_PATH=/app/lab-content
LAB_CONTENT_RETENTION=7d
LAB_CONTENT_GC_INTERVAL_MS=3600000
LAB_CONTENT_MAX_FILE_SIZE=10MB
LAB_CONTENT_MAX_REQUEST_SIZE=12MB
FMU_DATA_PATH=/app/fmu-data
